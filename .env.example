# Copy to .env and fill in the values

PORT=3001
NODE_ENV=development

# Firebase Admin SDK — service account JSON encoded as base64
# How to get it:
#   1. Firebase Console → Project Settings → Service Accounts
#   2. "Generate new private key" → download JSON
#   3. Run: base64 -w 0 serviceAccountKey.json
#   4. Paste the output below
FIREBASE_SERVICE_ACCOUNT=

# Firebase Realtime Database URL (find it in Firebase Console → Realtime Database)
FIREBASE_DATABASE_URL=https://feric-9d964-default-rtdb.europe-west1.firebasedatabase.app

# Cron schedule (default: 6 AM every day)
# Server timezone matters — set TZ=Europe/Ljubljana on Railway
CRON_SCHEDULE=0 6 * * *

# Days of change history to keep in Firebase (default: 30)
CHANGE_HISTORY_DAYS=30
